---
import { readFileSync } from 'fs';
import { parse } from 'yaml';

const logos = parse(readFileSync('src/content/tech.yaml', 'utf-8')) as {
    name: string; slug: string; color: string; href: string;
}[];

const track = [...logos, ...logos];
---

<section class="marquee">
    <header class="head container">
        <span class="mono tag">/ stack</span>
        <h2>tools i've used</h2>
    </header>

    <div class="logos">
        <div class="track">
            {track.map((logo) => (
                <a href={logo.href} target="_blank" rel="noopener noreferrer" aria-label={logo.name}>
                    <img
                        src={`https://cdn.simpleicons.org/${logo.slug}/${logo.color}`}
                        alt={logo.name}
                        loading="lazy"
                    />
                </a>
            ))}
        </div>
    </div>
</section>

<style lang="scss">
    .marquee {
        padding: 2rem 0 4rem;
    }

    .head {
        padding: 0 1.5rem;
        margin-bottom: 2rem;

        .tag {
            display: block;
            color: var(--text-dim);
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }

        h2 {
            color: var(--text);
            font-size: clamp(1.75rem, 3.5vw, 2.25rem);
            font-weight: 700;
        }
    }

    @keyframes slide {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
    }

    .logos {
        overflow: hidden;
        position: relative;
        padding: 2rem 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        background: var(--surface);
        mask-image: linear-gradient(
            to right,
            transparent,
            #000 10%,
            #000 90%,
            transparent
        );
        -webkit-mask-image: linear-gradient(
            to right,
            transparent,
            #000 10%,
            #000 90%,
            transparent
        );

        &:hover .track {
            animation-play-state: paused;
        }
    }

    .track {
        display: flex;
        gap: 3.5rem;
        width: max-content;
        animation: slide 80s linear infinite;

        a {
            display: flex;
            align-items: center;
            opacity: 0.65;
            transition: opacity 0.25s ease, transform 0.25s ease;

            &:hover {
                opacity: 1;
                transform: scale(1.15);
            }
        }

        img {
            height: 2.5rem;
            width: auto;
        }
    }
</style>
