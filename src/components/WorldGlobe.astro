---
---
<div class="globe-wrap">
  <svg class="globe-svg"></svg>
  <span class="globe-hint mono">drag to rotate</span>
</div>

<style lang="scss">
  .globe-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.75rem;
    cursor: grab;

    &:active { cursor: grabbing; }
  }

  .globe-svg {
    width: 100%;
    flex: 1;
    min-height: 0;
    overflow: visible;

    :global(.sphere) {
      fill: var(--surface-2);
      stroke: var(--border);
      stroke-width: 1.5;
    }

    :global(.graticule) {
      fill: none;
      stroke: var(--border);
      stroke-width: 0.3;
      opacity: 0.4;
    }

    :global(.country) {
      fill: var(--surface);
      stroke: var(--border);
      stroke-width: 0.4;
    }

    :global(.country.visited) {
      fill: var(--yellow);
      opacity: 0.88;
      stroke-width: 0.6;
    }

    :global(.country:hover) {
      filter: brightness(1.2);
    }
  }

  .globe-hint {
    font-size: 0.72rem;
    color: var(--text-dim);
  }
</style>

<script>
  import * as d3 from 'd3';
  import { feature } from 'topojson-client';
  import type { Topology } from 'topojson-specification';

  // ISO 3166-1 numeric codes
  const VISITED = new Set([840, 124, 826, 250, 276, 528, 784, 356]);

  document.addEventListener('DOMContentLoaded', async () => {
    const wrap = document.querySelector<HTMLElement>('.globe-wrap');
    const svgEl = document.querySelector<SVGSVGElement>('.globe-svg');
    if (!wrap || !svgEl) return;

    const size = Math.min(wrap.clientWidth, wrap.clientHeight - 32);
    const W = size, H = size;
    svgEl.setAttribute('viewBox', `0 0 ${W} ${H}`);

    const projection = d3.geoOrthographic()
      .scale((Math.min(W, H) - 4) / 2)
      .translate([W / 2, H / 2])
      .clipAngle(90)
      .rotate([-15, -30]);

    const path = d3.geoPath().projection(projection);
    const svg = d3.select(svgEl);

    svg.append('path')
      .datum({ type: 'Sphere' } as GeoJSON.GeoJsonObject)
      .attr('class', 'sphere')
      .attr('d', path as unknown as string);

    const graticule = d3.geoGraticule();
    svg.append('path')
      .datum(graticule())
      .attr('class', 'graticule')
      .attr('d', path as unknown as string);

    const world = await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json')
      .then(r => r.json()) as Topology;

    const countries = feature(world, world.objects['countries'] as any);

    svg.selectAll<SVGPathElement, GeoJSON.Feature>('.country')
      .data((countries as GeoJSON.FeatureCollection).features)
      .join('path')
      .attr('class', d => `country${VISITED.has(+(d.id ?? 0)) ? ' visited' : ''}`)
      .attr('d', path as unknown as string);

    const redraw = () => svg.selectAll<SVGPathElement, unknown>('path').attr('d', path as unknown as string);

    let dragging = false;
    svg.call(
      d3.drag<SVGSVGElement, unknown>()
        .on('start', () => { dragging = true; })
        .on('drag', event => {
          const [rx, ry, rz] = projection.rotate();
          projection.rotate([rx + event.dx * 0.5, ry - event.dy * 0.5, rz]);
          redraw();
        })
        .on('end', () => { dragging = false; })
    );

    d3.timer(() => {
      if (dragging) return;
      const [rx, ry, rz] = projection.rotate();
      projection.rotate([rx + 0.12, ry, rz]);
      redraw();
    });
  });
</script>
