---
import { execSync } from 'child_process';
import { INFO } from '../consts';

const year = new Date().getFullYear();

let commitHash = '';
let commitMsg = '';
let commitDate = '';
try {
    commitHash = execSync('git log -1 --format=%h').toString().trim();
    commitMsg  = execSync('git log -1 --format=%s').toString().trim();
    commitDate = execSync('git log -1 --format=%cd --date=short').toString().trim();
} catch {}

const commitUrl = `https://github.com/${INFO.github}/${INFO.repo}/commit/${commitHash}`;
---

<footer class="footer">
    <div class="container inner">
        <div class="left">
            <span class="mono">made with <span class="heart">♥</span> by {INFO.name}</span>
            <span class="mono dim">© {year} — built w/ astro + sass</span>
        </div>
        {commitHash && (
            <a class="commit mono" href={commitUrl} target="_blank" rel="noopener">
                <i class="bi bi-git"></i>
                <span class="hash">{commitHash}</span>
                <span class="msg">{commitMsg}</span>
                <span class="date dim">{commitDate}</span>
            </a>
        )}
        <div class="right">
            <a href={`https://github.com/${INFO.github}`} target="_blank" rel="noopener">
                <i class="bi bi-github"></i>
            </a>
            <a href={`mailto:${INFO.email}`}>
                <i class="bi bi-envelope-fill"></i>
            </a>
        </div>
    </div>
</footer>

<style lang="scss">
    .footer {
        border-top: 1px solid var(--border);
        padding: 2.5rem 0;
        margin-top: 4rem;
    }

    .inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .left {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        font-size: 0.9rem;
        color: var(--text-muted);

        .dim {
            color: var(--text-dim);
            font-size: 0.8rem;
        }
    }

    .heart {
        color: var(--red);
    }

    .commit {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.78rem;
        color: var(--text-dim);
        text-decoration: none;
        padding: 0.35rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        transition: color 0.2s ease, border-color 0.2s ease;
        max-width: 28rem;
        overflow: hidden;

        &:hover { color: var(--text-muted); border-color: var(--accent); }

        .hash { color: var(--accent); flex-shrink: 0; }
        .msg  { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .date { flex-shrink: 0; }
    }

    .right {
        display: flex;
        gap: 1rem;

        a {
            color: var(--text-muted);
            font-size: 1.35rem;
            transition: color 0.2s ease, transform 0.2s ease;

            &:hover {
                color: var(--red);
                transform: translateY(-2px);
            }
        }
    }
</style>
