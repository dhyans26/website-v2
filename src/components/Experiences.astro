---
import { readFileSync } from 'node:fs';
import { parse } from 'yaml';
import NorthAmericaMap from './NorthAmericaMap.astro';
import WorldGlobe from './WorldGlobe.astro';

const visitedData = parse(readFileSync('src/content/visited-states.yaml', 'utf-8'));
const usaCount = (visitedData['visited-usa'] || []).length;
const caCount = (visitedData['visited-canada'] || []).length;

interface Experience {
    role: string;
    org: string;
    period: string;
    description: string;
    icon: string;
    accent: string;
}

interface Hackathon {
    name: string;
    location: string;
    period: string;
    description: string;
    image: string;
}

interface Props {
    experiences: Experience[];
    hackathons: Hackathon[];
}

const { experiences = [], hackathons = [] } = Astro.props;
---

<section class="xp-section container">
    <header class="section-head">
        <span class="mono tag">/ experience</span>
        <div class="head-row">
            <h2>where i've been</h2>
        </div>
    </header>

    <div class="bento">

        <!-- ── left: tall travels card ── -->
        <article class="travels-card">
            <div class="travels-label mono">
                <i class="bi bi-globe2"></i> places i've traveled
            </div>
            <div class="map-wrap">
                <NorthAmericaMap />
            </div>
            <div class="travels-footer mono">
                {usaCount} states &nbsp;·&nbsp; {caCount} canadian provinces
            </div>
        </article>

        <!-- ── right: experience cards + hackathons ── -->
        <div class="right-col">
            <div class="exp-sub">
                {experiences.map((e: Experience, i: number) => (
                    <article class={`exp-card accent-${e.accent} idx-${i}`}>
                        <div class="exp-top">
                            <span class="exp-icon">
                                <i class={`bi ${e.icon}`}></i>
                            </span>
                            <span class="period mono">{e.period}</span>
                        </div>
                        <div class="exp-body">
                            <span class="role">{e.role}</span>
                            <span class="org mono">@ {e.org}</span>
                            <p set:html={e.description} />
                        </div>
                    </article>
                ))}
                <article class="exp-card globe-card">
                    <WorldGlobe />
                </article>
            </div>

            <div class="hackathons-section">
                <span class="hackathons-eyebrow mono"><i class="bi bi-trophy-fill"></i> hackathons</span>
                <div class="hackathons-grid">
                    {hackathons.map((h: Hackathon) => (
                        <article class="h-card">
                            {h.image && (
                                <div class="h-thumb">
                                    <img src={h.image} alt={h.name} loading="lazy" />
                                </div>
                            )}
                            <div class="h-body">
                                <div class="h-meta">
                                    <span class="h-name">{h.name}</span>
                                    {(h.location || h.period) && (
                                        <span class="h-sub mono">{[h.location, h.period].filter(Boolean).join(' · ')}</span>
                                    )}
                                </div>
                                {h.description && <p class="h-desc">{h.description}</p>}
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </div>

    </div>

    <p class="section-footer mono">seems sparse? i'm trying to keep my digital footprint to a minimum as much as possible; <a href="/contact">get in touch</a> for more details!</p>
</section>

<style lang="scss">
    .xp-section {
        padding: 2rem 1.5rem 4rem;
    }

    .section-head {
        margin-bottom: 2rem;

        .tag {
            display: block;
            color: var(--text-dim);
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }
    }

    .head-row {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        flex-wrap: wrap;

        h2 {
            color: var(--text);
            font-size: clamp(2rem, 4vw, 2.75rem);
            font-weight: 700;
        }
    }

    /* ── outer bento: travels | exp-sub ── */
    .bento {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        align-items: start;

        @media (max-width: 900px) {
            grid-template-columns: 1fr;
        }
    }

    /* ── travels card ── */
    .travels-card {
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 1.25rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: border-color 0.3s ease;

        &:hover {border-color: var(--yellow); }
    }

    .travels-label {
        padding: 1rem 1.25rem 0.75rem;
        font-size: 0.85rem;
        color: var(--text-dim);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-bottom: 1px solid var(--border);
    }

    .map-wrap {
        flex: 1;
        padding: 0.5rem 0.75rem;
        min-height: 0; // let flex shrink properly
    }

    .travels-footer {
        padding: 0.65rem 1.25rem;
        font-size: 0.78rem;
        color: var(--text-dim);
        border-top: 1px solid var(--border);
        text-align: center;
    }

    /* ── right column wrapper ── */
    .right-col {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    /* ── right sub-grid: 2 cols × auto rows ── */
    .exp-sub {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;

        // 3rd card spans full bottom row
        .idx-2 { grid-column: 1 / 3; }

        @media (max-width: 900px) {
            // on mobile the sub-grid goes single-col
            grid-template-columns: 1fr;
            grid-template-rows: unset;

            .idx-2 { grid-column: unset; }
        }
    }

    /* ── individual experience cards ── */
    .exp-card {
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 1.25rem;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        transition: transform 0.3s ease, border-color 0.3s ease;

        &:hover { transform: translateY(-4px); }

        &.accent-red:hover    { border-color: var(--red); }
        &.accent-blue:hover   { border-color: var(--blue); }
        &.accent-yellow:hover { border-color: var(--yellow); }
        &.accent-purple:hover { border-color: var(--purple); }
        &.accent-pink:hover   { border-color: var(--pink); }
        &.accent-green:hover  { border-color: var(--green); }

        &.globe-card {
            padding: 0;
            min-height: 220px;
            overflow: hidden;
            &:hover { border-color: var(--yellow); transform: translateY(-4px); }
        }
    }

    .exp-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .exp-icon {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 0.6rem;
        background: var(--surface-2);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;

        i { font-size: 1rem; color: var(--text-muted); }
    }

    .period {
        font-size: 0.75rem;
        color: var(--text-dim);
    }

    .exp-body {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        flex-grow: 1;
    }

    .role {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--text);
        text-transform: lowercase;
        letter-spacing: -0.02em;
    }

    .org {
        font-size: 0.78rem;
        color: var(--text-dim);
        margin-bottom: 0.45rem;
    }

    .exp-body :global(a) {
        color: var(--accent);
        text-decoration: none;
        &:hover { text-decoration: underline; }
    }

    p {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
        flex-grow: 1;
    }

    /* ── hackathons section ── */
    .hackathons-section {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .hackathons-eyebrow {
        font-size: 0.85rem;
        color: var(--text-dim);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .hackathons-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;

        @media (max-width: 600px) {
            grid-template-columns: 1fr;
        }
    }

    .h-card {
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 1.25rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease, border-color 0.3s ease;

        &:hover {
            transform: translateY(-4px);
            border-color: var(--accent);
        }
    }

    .h-thumb {
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: var(--surface-2);

        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.4s ease;
        }

        .h-card:hover & img { transform: scale(1.04); }
    }

    .h-body {
        padding: 1rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex-grow: 1;
    }

    .h-meta {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }

    .h-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
        text-transform: lowercase;
        letter-spacing: -0.02em;
    }

    .h-sub {
        font-size: 0.75rem;
        color: var(--text-dim);
    }

    .h-desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
        flex-grow: 1;
    }

    .section-footer {
        margin-top: 1.25rem;
        font-size: 0.78rem;
        color: var(--text-dim);
        flex-grow: unset;
        line-height: 1.5;

        a { color: var(--accent); text-decoration: none; &:hover { text-decoration: underline; } }
    }
</style>
