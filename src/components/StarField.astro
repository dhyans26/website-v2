---
function prng(seed: number) {
    let s = seed;
    return () => {
        s = (s * 1664525 + 1013904223) % 4294967296;
        return s / 4294967296;
    };
}

function starShadows(count: number, spread: number, seed: number, maxBright = 1) {
    const rand = prng(seed);
    const parts: string[] = [];
    for (let i = 0; i < count; i++) {
        const x = Math.floor(rand() * spread);
        const y = Math.floor(rand() * spread);
        const b = (0.5 + rand() * (maxBright - 0.5)).toFixed(2);
        parts.push(`${x}px ${y}px rgba(255,255,255,${b})`);
    }
    return parts.join(', ');
}

const SPREAD = 3000;
const far   = starShadows(700, SPREAD, 7,    0.85);
const mid   = starShadows(250, SPREAD, 42,   0.95);
const near  = starShadows(90,  SPREAD, 1337, 1);
const focal = starShadows(1,   SPREAD, 99,   1);

// shooting star spawn points — top-right sky area
const shoots = [
    { top: '8%',  left: '78%', delay: '1s',   dur: '2.8s' },
    { top: '20%', left: '58%', delay: '5s',   dur: '3.2s' },
    { top: '4%',  left: '90%', delay: '9s',   dur: '2.5s' },
    { top: '28%', left: '72%', delay: '14s',  dur: '3.0s' },
    { top: '13%', left: '46%', delay: '19s',  dur: '2.8s' },
    { top: '6%',  left: '63%', delay: '24s',  dur: '3.4s' },
];
---

<div class="starfield" aria-hidden="true">
    <div class="nebula"></div>
    <div class="stars layer-far"   style={`box-shadow: ${far}`}></div>
    <div class="stars layer-mid"   style={`box-shadow: ${mid}`}></div>
    <div class="stars layer-near"  style={`box-shadow: ${near}`}></div>
    <div class="stars layer-focal" style={`box-shadow: ${focal}`}></div>
    <div class="shoots">
        {shoots.map(s => (
            <span
                class="shoot"
                style={`top:${s.top};left:${s.left};animation-delay:${s.delay};animation-duration:${s.dur}`}
            />
        ))}
    </div>
    <div class="planet"></div>
</div>

<script>
    // --- scroll parallax ---
    let scrollY = 0;
    let scrollTicking = false;

    const onScroll = () => {
        scrollY = window.scrollY;
        if (!scrollTicking) {
            requestAnimationFrame(() => {
                document.documentElement.style.setProperty('--scroll', String(scrollY));
                scrollTicking = false;
            });
            scrollTicking = true;
        }
    };
    window.addEventListener('scroll', onScroll, { passive: true });

    // --- mouse parallax (lerped for smoothness) ---
    let targetX = 0, targetY = 0;
    let mouseX  = 0, mouseY  = 0;

    window.addEventListener('mousemove', (e) => {
        targetX = (e.clientX / window.innerWidth  - 0.5) * 11.2;
        targetY = (e.clientY / window.innerHeight - 0.5) * 11.2;
    }, { passive: true });

    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    const tickMouse = () => {
        mouseX = lerp(mouseX, targetX, 0.06);
        mouseY = lerp(mouseY, targetY, 0.06);
        document.documentElement.style.setProperty('--mouse-x', `${mouseX.toFixed(2)}px`);
        document.documentElement.style.setProperty('--mouse-y', `${mouseY.toFixed(2)}px`);
        requestAnimationFrame(tickMouse);
    };
    tickMouse();
</script>

<style lang="scss">
    .starfield {
        position: fixed;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
        z-index: -1;
    }

    .nebula {
        position: absolute;
        inset: -10%;
        background:
            radial-gradient(ellipse 55% 45% at 18% 22%, rgba(170, 153, 255, 0.28), transparent 55%),
            radial-gradient(ellipse 45% 35% at 82% 62%, rgba(153, 221, 255, 0.18), transparent 60%),
            radial-gradient(ellipse 60% 45% at 55% 105%, rgba(255, 153, 255, 0.12), transparent 60%);
        transform: translate3d(
            calc(var(--mouse-x, 0px) * -0.04),
            calc(var(--mouse-y, 0px) * -0.04 + var(--scroll, 0) * -0.016px),
            0
        );
        will-change: transform;
    }

    .stars {
        position: absolute;
        top: -50vh;
        left: 0;
        width: 1px;
        height: 1px;
        background: transparent;
        border-radius: 50%;

        &::after {
            content: "";
            position: absolute;
            top: 3000px;
            left: 0;
            width: inherit;
            height: inherit;
            background: transparent;
            box-shadow: inherit;
            border-radius: inherit;
        }
    }

    .layer-far {
        transform: translate3d(
            calc(var(--mouse-x, 0px) * 0.06),
            calc(var(--mouse-y, 0px) * 0.06 + var(--scroll, 0) * 0.032px),
            0
        );
        animation: twinkle-a 7s ease-in-out infinite;
        will-change: transform;
    }

    .layer-mid {
        width: 2px;
        height: 2px;
        transform: translate3d(
            calc(var(--mouse-x, 0px) * 0.16),
            calc(var(--mouse-y, 0px) * 0.16 + var(--scroll, 0) * 0.088px),
            0
        );
        animation: twinkle-b 5s ease-in-out infinite;
        will-change: transform;
    }

    .layer-near {
        width: 3px;
        height: 3px;
        transform: translate3d(
            calc(var(--mouse-x, 0px) * 0.32),
            calc(var(--mouse-y, 0px) * 0.32 + var(--scroll, 0) * 0.18px),
            0
        );
        animation: twinkle-a 4s ease-in-out infinite;
        will-change: transform;
    }

    .layer-focal {
        width: 4px;
        height: 4px;
        transform: translate3d(
            calc(var(--mouse-x, 0px) * 0.2),
            calc(var(--mouse-y, 0px) * 0.2 + var(--scroll, 0) * 0.12px),
            0
        );
        filter: drop-shadow(0 0 6px rgba(255, 238, 153, 0.9));
        animation: twinkle-a 3s ease-in-out infinite;
        will-change: transform;
    }

    // --- shooting stars ---
    .shoots {
        position: absolute;
        inset: 0;
    }

    .shoot {
        position: absolute;
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: #fff;
        box-shadow: 0 0 6px 2px rgba(255, 238, 153, 0.7);
        opacity: 0;
        animation: shoot var(--dur, 3s) var(--delay, 0s) linear infinite;

        // tail: gradient line extending NE (behind the SW-moving head)
        &::after {
            content: "";
            position: absolute;
            top: 1px;
            left: 2px;
            width: 110px;
            height: 1.5px;
            background: linear-gradient(to right, rgba(255, 255, 255, 0.85), transparent);
            transform-origin: left center;
            transform: rotate(-45deg);
        }
    }

    @keyframes shoot {
        0%   { opacity: 0;   transform: translate(0, 0); }
        6%   { opacity: 0.9; }
        85%  { opacity: 0.7; }
        100% { opacity: 0;   transform: translate(-550px, 550px); }
    }

    .planet {
        position: absolute;
        top: 12%;
        right: -4rem;
        width: 16rem;
        height: 16rem;
        border-radius: 50%;
        background:
            radial-gradient(circle at 35% 35%, rgba(170, 153, 255, 0.35), rgba(153, 221, 255, 0.18) 40%, transparent 70%);
        box-shadow: inset -2rem -2rem 4rem rgba(0, 0, 0, 0.6);
        filter: blur(1px);
        opacity: 0.7;
        transform: translate3d(
            calc(var(--mouse-x, 0px) * -0.08),
            calc(var(--mouse-y, 0px) * -0.08 + var(--scroll, 0) * -0.048px),
            0
        );
        will-change: transform;

        @media (max-width: 720px) {
            width: 10rem;
            height: 10rem;
            top: 8%;
            right: -2rem;
            opacity: 0.5;
        }
    }

    @keyframes twinkle-a {
        0%, 100% { opacity: 0.65; }
        50%      { opacity: 1; }
    }
    @keyframes twinkle-b {
        0%, 100% { opacity: 1; }
        50%      { opacity: 0.55; }
    }

    @media (prefers-reduced-motion: reduce) {
        .stars, .nebula, .planet, .layer-focal, .shoot {
            transform: none !important;
            animation: none !important;
            opacity: 1 !important;
        }
    }
</style>
