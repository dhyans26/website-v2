---
import { readFileSync } from 'node:fs';
import { parse } from 'yaml';

const visitedData = parse(readFileSync('src/content/visited-states.yaml', 'utf-8'));
const visitedUsaStates = new Set(visitedData['visited-usa'] || []);
const visitedCanadianProvinces = new Set(visitedData['visited-canada'] || []);
const unvisitedUsaStates = new Set(visitedData['visited-usa-not'] || []);

// Strip XML declaration so it does not render as text when injected.
const svgContent = readFileSync('public/experiences/north-america.svg', 'utf-8').replace(/<\?xml[^>]*\?>\s*/i, '');
---

<div class="map-container">
  <div class="map-content" set:html={svgContent}></div>

  <div class="legend">
    <div class="legend-item">
      <div class="legend-box visited"></div>
      <span>Visited States</span>
    </div>
    <div class="legend-item">
      <div class="legend-box visited-province"></div>
      <span>Visited Provinces</span>
    </div>
  </div>
</div>

<style lang="scss">
  .map-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .map-content {
    width: 100%;
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 1rem;
    padding: 0.15rem 0.75rem 0.5rem;
    overflow: hidden;

    :global(svg) {
      width: 100%;
      height: auto;
      min-height: 320px; // note: if i ever go to alaska, increase to like 400ish
      display: block;
    }

    :global(path[id]) {
      fill: var(--surface-2);
      stroke: var(--border);
      stroke-width: 0.7;
      opacity: 0.52;
      transition: opacity 0.2s ease, fill 0.2s ease, filter 0.2s ease;
      cursor: pointer;
    }

    :global(path[id]:hover) {
      opacity: 0.95;
      filter: brightness(1.15);
    }

    /* Make hover state differences more obvious (similar to how CA pops). */
    :global(path[id].visited-us:hover) {
      opacity: 1;
      filter: brightness(1.08) saturate(1.1);
    }

    :global(path[id].unvisited-us:hover) {
      opacity: 0.75;
      filter: brightness(1.2);
    }

    :global(path[id].visited-us) {
      fill: var(--yellow);
      opacity: 0.9;
      stroke-width: 0.9;
    }

    :global(path[id].visited-ca) {
      fill: var(--green);
      opacity: 0.88;
      stroke-width: 0.9;
    }

    :global(path[id].unvisited-us) {
      opacity: 0.42;
    }

    :global(text) {
      pointer-events: none;
      opacity: 0.4;
      fill: var(--text-muted);
    }
  }

  .legend {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    padding: 0.85rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    font-size: 0.9rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
  }

  .legend-box {
    width: 16px;
    height: 16px;
    border: 1px solid var(--border);
    border-radius: 0.2rem;
    flex-shrink: 0;

    &.visited { background: var(--yellow); opacity: 0.9; }
    &.visited-province { background: var(--green); opacity: 0.88; }
    &.unvisited { background: var(--surface-2); opacity: 0.35; }
  }

  @media (max-width: 900px) {
    .map-content :global(svg) {
      min-height: 460px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const visitedUsaStates = new Set([
      'AL', 'AZ', 'AR', 'CA', 'CO', 'CT', 'DE', 'FL', 'GA', 'IL', 'IN', 'IA',
      'KS', 'KY', 'LA', 'ME', 'MD', 'MA', 'MI', 'MN', 'MS', 'MO', 'NE', 'NV',
      'NH', 'NJ', 'NM', 'NY', 'NC', 'OH', 'OK', 'PA', 'RI', 'SC', 'SD', 'TN',
      'TX', 'UT', 'VT', 'VA', 'WA', 'WV', 'WI'
    ]);

    const unvisitedUsaStates = new Set(['AK', 'HI', 'ID', 'MT', 'ND', 'OR', 'WY']);
    const visitedCanada = new Set(['ON', 'QC']);

    const lower48 = [
      'AL', 'AZ', 'AR', 'CA', 'CO', 'CT', 'DE', 'FL', 'GA', 'IA', 'ID', 'IL', 'IN',
      'KS', 'KY', 'LA', 'MA', 'MD', 'ME', 'MI', 'MN', 'MO', 'MS', 'MT', 'NC', 'ND',
      'NE', 'NH', 'NJ', 'NM', 'NV', 'NY', 'OH', 'OK', 'OR', 'PA', 'RI', 'SC', 'SD',
      'TN', 'TX', 'UT', 'VA', 'VT', 'WA', 'WI', 'WV', 'WY'
    ];

    const nameMap: Record<string, string> = {
      AL: 'Alabama', AK: 'Alaska', AZ: 'Arizona', AR: 'Arkansas', CA: 'California',
      CO: 'Colorado', CT: 'Connecticut', DE: 'Delaware', FL: 'Florida', GA: 'Georgia',
      HI: 'Hawaii', ID: 'Idaho', IL: 'Illinois', IN: 'Indiana', IA: 'Iowa', KS: 'Kansas',
      KY: 'Kentucky', LA: 'Louisiana', ME: 'Maine', MD: 'Maryland', MA: 'Massachusetts',
      MI: 'Michigan', MN: 'Minnesota', MS: 'Mississippi', MO: 'Missouri', MT: 'Montana',
      NE: 'Nebraska', NV: 'Nevada', NH: 'New Hampshire', NJ: 'New Jersey', NM: 'New Mexico',
      NY: 'New York', NC: 'North Carolina', ND: 'North Dakota', OH: 'Ohio', OK: 'Oklahoma',
      OR: 'Oregon', PA: 'Pennsylvania', RI: 'Rhode Island', SC: 'South Carolina',
      SD: 'South Dakota', TN: 'Tennessee', TX: 'Texas', UT: 'Utah', VT: 'Vermont',
      VA: 'Virginia', WA: 'Washington', WV: 'West Virginia', WI: 'Wisconsin', WY: 'Wyoming',
      ON: 'Ontario', QC: 'Quebec', AB: 'Alberta', BC: 'British Columbia', MB: 'Manitoba',
      NB: 'New Brunswick', NL: 'Newfoundland and Labrador', NS: 'Nova Scotia',
      PE: 'Prince Edward Island', SK: 'Saskatchewan', YT: 'Yukon', NT: 'Northwest Territories',
      NU: 'Nunavut'
    };

    const svg = document.querySelector('.map-content svg') as SVGSVGElement | null;
    if (!svg) return;

    // Some source files use lowercase `viewbox`; normalize for reliable zooming.
    if (!svg.getAttribute('viewBox')) {
      const lower = svg.getAttribute('viewbox');
      if (lower) svg.setAttribute('viewBox', lower);
    }
    svg.setAttribute('preserveAspectRatio', 'xMidYMax meet');

    const paths = svg.querySelectorAll('path[id]');
    paths.forEach((path) => {
      const id = path.getAttribute('id');
      if (!id) return;

      const fullName = (nameMap as   Record<string, string>)[id] || id;
      if (visitedUsaStates.has(id)) path.classList.add('visited-us');
      else if (visitedCanada.has(id)) path.classList.add('visited-ca');
      else if (unvisitedUsaStates.has(id)) path.classList.add('unvisited-us');

      const visited = visitedUsaStates.has(id) || visitedCanada.has(id);
      path.setAttribute('title', visited ? `${fullName} - Visited` : fullName);
    });

    // Focus view on the contiguous US (AK/HI outside frame is acceptable).
    const focus: DOMRect[] = [];
    lower48.forEach((id) => {
      const p = svg.querySelector(`path#${id}`) as SVGGraphicsElement | null;
      if (p) focus.push(p.getBBox());
    });

    if (!focus.length) return;

    const minX = Math.min(...focus.map((b) => b.x));
    const minY = Math.min(...focus.map((b) => b.y));
    const maxX = Math.max(...focus.map((b) => b.x + b.width));
    const maxY = Math.max(...focus.map((b) => b.y + b.height));

    const width = maxX - minX;
    const height = maxY - minY;
    const padX = width * 0.07;
    // Keep top/bottom padding symmetric so the map doesn't "float" low.
    const padY = height * 0.02;

    svg.setAttribute('viewBox', `${minX - padX} ${minY - padY} ${width + padX * 2} ${height + padY * 2}`);
  });
</script>

