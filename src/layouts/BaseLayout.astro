---
import '../styles/globals.scss';
// self-hosted fonts — no CDN round-trips
import '@fontsource-variable/space-grotesk';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
// self-hosted icons
import 'bootstrap-icons/font/bootstrap-icons.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import ProjectModal from '../components/ProjectModal.astro';
import StarField from '../components/StarField.astro';
import { readFileSync } from 'fs';
import { parse } from 'yaml';

const { pageTitle } = Astro.props;

const accentConfig: Record<string, number> = parse(readFileSync('src/content/accent.yaml', 'utf-8')) ?? {};
const accentNames = JSON.stringify(Object.keys(accentConfig));
const accentWeights = JSON.stringify(Object.values(accentConfig));
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />

        <meta name="generator" content={Astro.generator} />
        <title>Dhyan: {pageTitle}</title>

        <script is:inline define:vars={{ accentNames, accentWeights }}>
            (function(){var p=sessionStorage.getItem('accent');if(!p){var a=JSON.parse(accentNames),w=JSON.parse(accentWeights),t=0,i,c=0;for(i=0;i<w.length;i++)t+=w[i];var r=Math.random()*t;p=a[0];for(i=0;i<a.length;i++){c+=w[i];if(r<c){p=a[i];break;}}sessionStorage.setItem('accent',p);}document.documentElement.dataset.accent=p;})();
        </script>
    </head>

    <body>
        <StarField />
        <Navigation />
        <main>
            <slot />
        </main>
        <Footer />
        <ProjectModal />
    </body>
</html>

<style is:global>
    main {
        min-height: calc(100vh - 14rem);
    }
</style>
