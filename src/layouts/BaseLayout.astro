---
import '../styles/globals.scss';
// self-hosted fonts — no CDN round-trips
import '@fontsource-variable/space-grotesk';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
// self-hosted icons
import 'bootstrap-icons/font/bootstrap-icons.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import ProjectModal from '../components/ProjectModal.astro';
import StarField from '../components/StarField.astro';

const { pageTitle } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />

        <meta name="generator" content={Astro.generator} />
        <title>Dhyan: {pageTitle}</title>
        <!-- restore accent theme before first paint to avoid flash -->
        <script is:inline>
            (function(){var a=localStorage.getItem('accent');if(a)document.documentElement.dataset.accent=a;})();
        </script>
    </head>

    <body>
        <StarField />
        <Navigation />
        <main>
            <slot />
        </main>
        <Footer />
        <ProjectModal />
    </body>
</html>

<style is:global>
    main {
        min-height: calc(100vh - 14rem);
    }
</style>
