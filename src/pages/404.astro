---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="404">
    <section class="void" id="void">

        <!-- parallax layer 1 — far debris -->
        <div class="layer" id="l1">
            <div class="debris d1"></div>
            <div class="debris d2"></div>
            <div class="debris d3"></div>
            <div class="debris d4"></div>
        </div>

        <!-- parallax layer 3 — content (moves least) -->
        <div class="layer" id="l3">
            <div class="content">
                <span class="eyebrow mono">// error</span>
                <h1 class="four-o-four">
                    <span>4</span><span class="accent-num">0</span><span>4</span>
                </h1>
                <p class="tagline mono">signal lost</p>
                <p class="desc">
                    this page drifted into the void.<br />
                    it might have been moved, deleted, or never existed.
                </p>
                <a href="/" class="btn">
                    <i class="bi bi-rocket-takeoff"></i> take me home
                </a>
            </div>
        </div>

    </section>
</BaseLayout>

<style lang="scss">
    .void {
        position: relative;
        min-height: calc(100vh - 14rem);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    /* ── parallax layers ── */
    .layer {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        will-change: transform;
    }

    /* ── floating debris ── */
    .debris {
        position: absolute;
        border-radius: 2px;
        background: var(--border);
        opacity: 0.55;

        &.d1 {
            width: 6px; height: 6px; border-radius: 50%;
            top: 15%; left: 8%;
            background: var(--purple);
            box-shadow: 0 0 8px var(--purple);
            animation: float-d 7s ease-in-out infinite;
        }
        &.d2 {
            width: 4px; height: 10px;
            top: 70%; left: 14%;
            transform: rotate(35deg);
            animation: float-d 9s ease-in-out infinite 1s;
        }
        &.d3 {
            width: 8px; height: 8px; border-radius: 50%;
            top: 25%; right: 18%;
            background: var(--blue);
            box-shadow: 0 0 10px var(--blue);
            opacity: 0.4;
            animation: float-d 11s ease-in-out infinite 2s;
        }
        &.d4 {
            width: 5px; height: 5px;
            top: 78%; right: 22%;
            transform: rotate(-20deg);
            animation: float-d 8s ease-in-out infinite 3s;
        }
    }

    @keyframes float-d {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50%       { transform: translateY(-12px) rotate(15deg); }
    }

    /* ── content ── */
    .content {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        position: relative;
        z-index: 1;
        padding: 0 1.5rem;
    }

    .eyebrow {
        color: var(--text-dim);
        font-size: 0.9rem;
        letter-spacing: 0.06em;
    }

    .four-o-four {
        font-size: clamp(6rem, 18vw, 12rem);
        font-weight: 700;
        letter-spacing: -0.04em;
        line-height: 1;
        margin: 0;
        display: flex;
        gap: 0.05em;

        span { color: var(--text); }

        .accent-num {
            color: var(--accent);
            text-shadow:
                0 0 40px color-mix(in srgb, var(--accent) 60%, transparent),
                0 0 80px color-mix(in srgb, var(--accent) 25%, transparent);
            animation: pulse-glow 3s ease-in-out infinite;
        }
    }

    @keyframes pulse-glow {
        0%, 100% { text-shadow:
            0 0 30px color-mix(in srgb, var(--accent) 55%, transparent),
            0 0 70px color-mix(in srgb, var(--accent) 20%, transparent); }
        50%       { text-shadow:
            0 0 55px color-mix(in srgb, var(--accent) 75%, transparent),
            0 0 110px color-mix(in srgb, var(--accent) 35%, transparent); }
    }

    .tagline {
        color: var(--text-dim);
        font-size: 0.95rem;
        letter-spacing: 0.08em;
        margin: 0;
    }

    .desc {
        color: var(--text-muted);
        font-size: 1rem;
        line-height: 1.65;
        max-width: 26rem;
        margin: 0;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        padding: 0.75rem 1.4rem;
        border-radius: 999px;
        font-size: 1rem;
        font-weight: 500;
        border: 2px solid transparent;
        background: var(--accent);
        color: var(--bg);
        transition: all 0.2s ease;

        &:hover {
            background: var(--yellow);
            color: var(--bg);
            box-shadow: 0 0 0 6px var(--yellow-40);
        }
    }
</style>

<script>
    const void_el = document.getElementById('void')!;
    const layers = [
        { el: document.getElementById('l1')!, rx: 0.045, ry: 0.045 },
        { el: document.getElementById('l3')!, rx: 0.008, ry: 0.008 },
    ];

    let tx = [0, 0], ty = [0, 0];
    let cx = [0, 0], cy = [0, 0];
    let raf = 0;

    function tick() {
        layers.forEach((l, i) => {
            cx[i] += (tx[i] - cx[i]) * 0.07;
            cy[i] += (ty[i] - cy[i]) * 0.07;
            l.el.style.transform = `translate(${cx[i]}px, ${cy[i]}px)`;
        });
        raf = requestAnimationFrame(tick);
    }

    void_el.addEventListener('mousemove', (e) => {
        const r = void_el.getBoundingClientRect();
        const mx = (e.clientX - r.left  - r.width  / 2);
        const my = (e.clientY - r.top   - r.height / 2);
        layers.forEach((l, i) => {
            tx[i] =  mx * l.rx;
            ty[i] =  my * l.ry;
        });
    });

    void_el.addEventListener('mouseleave', () => {
        layers.forEach((_, i) => { tx[i] = 0; ty[i] = 0; });
    });

    raf = requestAnimationFrame(tick);
</script>
