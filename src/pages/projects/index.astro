---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFileSync, writeFileSync, mkdirSync, existsSync } from 'fs';
import { parse } from 'yaml';
import { INFO } from '../../consts';

const projects = parse(readFileSync('src/content/projects.yaml', 'utf-8'));
const isVideo = (src: string) => /\.(mp4|webm|mov|ogg)(\?|$)/i.test(src);
const cleanMedia = (raw: any[]) => (raw ?? []).filter(Boolean);

type LatestCommit = {
    message: string;
    repoName: string;
    sha: string;
    url: string;
    ago: string;
};

function timeAgo(date: Date): string {
    const mins = Math.floor((Date.now() - date.getTime()) / 60000);
    if (mins < 60) return `${mins}m ago`;
    if (mins < 1440) return `${Math.floor(mins / 60)}h ago`;
    return `${Math.floor(mins / 1440)}d ago`;
}

const repoSlugs = (projects as any[])
    .map((p: any) => p.github)
    .filter(Boolean)
    .map((url: string) => url.replace('https://github.com/', ''))
    .filter((slug: string) => /^[\w.-]+\/[\w.-]+$/.test(slug));

const CACHE_FILE = '.cache/github-commits.json';
const CACHE_TTL  = 10 * 60 * 1000; // 10 minutes

type CacheEntry = { fetchedAt: number; results: any[] };

function readCache(): CacheEntry | null {
    try {
        const raw = readFileSync(CACHE_FILE, 'utf-8');
        const entry: CacheEntry = JSON.parse(raw);
        if (Date.now() - entry.fetchedAt < CACHE_TTL) return entry;
    } catch {}
    return null;
}

function writeCache(results: any[]) {
    try {
        mkdirSync('.cache', { recursive: true });
        writeFileSync(CACHE_FILE, JSON.stringify({ fetchedAt: Date.now(), results }));
    } catch {}
}

const cached = readCache();
const commitResults: any[] = cached
    ? cached.results
    : await (async () => {
        const results = await Promise.all(
            repoSlugs.map(async (slug: string) => {
                try {
                    const resp = await fetch(`https://api.github.com/repos/${slug}/commits?per_page=1`);
                    if (!resp.ok) return null;
                    const [c] = await resp.json();
                    if (!c) return null;
                    return {
                        message: c.commit.message.split('\n')[0],
                        repoName: slug.split('/')[1],
                        sha: c.sha.slice(0, 7),
                        url: c.html_url,
                        date: new Date(c.commit.committer.date).toISOString(),
                    };
                } catch { return null; }
            })
        );
        writeCache(results);
        return results;
    })();

const best = commitResults
    .filter(Boolean)
    .sort((a, b) => new Date(b!.date).getTime() - new Date(a!.date).getTime())[0] ?? null;

const latestCommit: LatestCommit | null = best
    ? { ...best!, ago: timeAgo(new Date(best!.date)) }
    : null;

const now = new Date();
const refreshedAt = `${(now.getMonth() + 1).toString().padStart(2, '0')}/${now.getDate().toString().padStart(2, '0')} ${now.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }).toLowerCase()}`;
---

<BaseLayout pageTitle="Projects">
    <section class="container page">
        <header class="head">
            <span class="mono tag">/ projects</span>
            <h1>things i've built</h1>
            <p>some of the fun stuff i've made!</p>
            {latestCommit && (
                <div class="commit-wrap">
                <span class="commit-label mono">most recent commit · refreshed {refreshedAt}</span>
                <a class="commit-strip mono" href={latestCommit.url} target="_blank" rel="noopener noreferrer">
                    <i class="bi bi-git"></i>
                    <span class="commit-msg">{latestCommit.message}</span>
                    <span class="commit-meta">
                        <span class="repo">{latestCommit.repoName}</span>
                        <span class="dot-sep">·</span>
                        <span class="ago">{latestCommit.ago}</span>
                        <span class="dot-sep">·</span>
                        <span class="sha">{latestCommit.sha}</span>
                        <i class="bi bi-arrow-up-right"></i>
                    </span>
                </a>
                </div>
            )}
        </header>

        <div class="grid">
            {projects.map((p: any, i: number) => {
                const media = cleanMedia(p.media);
                const thumb = media[0];
                return (
                    <article
                        class="proj"
                        data-project={JSON.stringify({ title: p.title, description: p.description, tech: p.tech, github: p.github, live: p.live ?? null, media })}
                    >
                        {thumb && (
                            <div class="thumb">
                                {isVideo(thumb)
                                    ? <video src={thumb} muted loop autoplay playsinline />
                                    : <img src={thumb} alt={p.title} loading="lazy" />
                                }
                                <div class="thumb-overlay">
                                    {media.length > 1 && <span class="count mono"><i class="bi bi-images"></i> {media.length}</span>}
                                    <i class="bi bi-arrows-fullscreen expand-icon"></i>
                                </div>
                            </div>
                        )}

                        <div class="body">
                            <div class="top">
                                <span class="mono idx">{String(i + 1).padStart(2, '0')}</span>
                                <div class="ext-links">
                                    <a href={p.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                                        <i class="bi bi-github"></i>
                                    </a>
                                    {p.live && (
                                        <a href={p.live} target="_blank" rel="noopener noreferrer" aria-label="Live">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </a>
                                    )}
                                </div>
                            </div>
                            <h3>{p.title}</h3>
                            <p>{p.description}</p>
                            <div class="tags">
                                {p.tech.map((t: string) => (
                                    <span class="tag-pill mono">{t}</span>
                                ))}
                            </div>
                        </div>
                    </article>
                );
            })}
        </div>
    </section>
</BaseLayout>

<style lang="scss">
    .page {
        padding: 3rem 1.5rem 4rem;
    }

    .head {
        margin-bottom: 3rem;
        max-width: 40rem;

        .tag { display: block; color: var(--text-dim); font-size: 0.9rem; margin-bottom: 0.5rem; }
        h1   { margin-bottom: 0.75rem; text-transform: lowercase; }
        p    { font-size: 1.1rem; margin-bottom: 1rem; }
    }

    .commit-wrap {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .commit-label {
        font-size: 0.7rem;
        color: var(--text-dim);
        letter-spacing: 0.04em;
    }

    .commit-strip {
        display: inline-flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        padding: 0.45rem 0.85rem;
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 0.6rem;
        font-size: 0.78rem;
        color: var(--text-muted);
        text-decoration: none;
        transition: border-color 0.2s ease, color 0.2s ease;
        max-width: 100%;

        &:hover {
            border-color: var(--accent);
            color: var(--text);
        }

        .bi-git { color: var(--text-dim); flex-shrink: 0; }

        .commit-msg {
            color: var(--text);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 22rem;
        }

        .commit-meta {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            flex-shrink: 0;
        }

        .repo   { color: var(--accent); }
        .ago    { color: var(--text-dim); }
        .sha    { color: var(--text-dim); letter-spacing: 0.04em; }
        .dot-sep { color: var(--border); }

        .bi-arrow-up-right { font-size: 0.7rem; color: var(--text-dim); }
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
        gap: 1.5rem;
    }

    .proj {
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 1.25rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        cursor: pointer;
        transition: transform 0.3s ease, border-color 0.3s ease;

        &:hover {
            transform: translateY(-4px);
            border-color: var(--red);
        }
    }

    .thumb {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: var(--surface-2);

        img, video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            padding: 0;
            margin: 0;
            border-radius: 0;
            transition: transform 0.4s ease;
        }

        .thumb-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0);
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            padding: 0.6rem 0.75rem;
            transition: background 0.25s ease;

            .count {
                font-size: 0.75rem;
                color: rgba(255,255,255,0);
                display: flex;
                align-items: center;
                gap: 0.3rem;
                transition: color 0.25s ease;
            }

            .expand-icon {
                font-size: 0.9rem;
                color: rgba(255,255,255,0);
                transition: color 0.25s ease;
            }
        }

        &:hover img,
        &:hover video { transform: scale(1.04); }
    }

    .proj:hover .thumb-overlay {
        background: rgba(0, 0, 0, 0.35);
        .count, .expand-icon { color: rgba(255,255,255,0.9); }
    }

    .body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        flex-grow: 1;
    }

    .top {
        display: flex;
        justify-content: space-between;
        align-items: center;

        .idx { color: var(--text-dim); font-size: 0.85rem; }

        .ext-links {
            display: flex;
            gap: 0.75rem;
            a { color: var(--text-muted); font-size: 1.15rem; &:hover { color: var(--red); } }
        }
    }

    h3 { font-size: 1.5rem; text-transform: lowercase; }
    p  { flex-grow: 1; font-size: 1rem; }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .tag-pill {
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.2rem 0.7rem;
        font-size: 0.75rem;
        color: var(--text-muted);
    }
</style>
