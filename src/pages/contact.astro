---
import BaseLayout from '../layouts/BaseLayout.astro';
import { INFO } from '../consts';

const channels = [
    {
        icon: 'bi-envelope-fill',
        label: 'email',
        value: INFO.email,
        href: `mailto:${INFO.email}`,
        color: 'red',
    },
    {
        icon: 'bi-github',
        label: 'github',
        value: `@${INFO.github}`,
        href: `https://github.com/${INFO.github}`,
        color: 'blue',
    },
];
---

<BaseLayout pageTitle="Contact">
    <section class="container page">
        <header class="head">
            <span class="mono tag">/ contact</span>
            <h1>let's talk</h1>
            <p>
                i'd love to get in touch!
            </p>
        </header>

        <div class="channels">
            {channels.map((c) => (
                <a href={c.href} class={`ch ch-${c.color}`} target="_blank" rel="noopener noreferrer">
                    <div class="icon">
                        <i class={`bi ${c.icon}`}></i>
                    </div>
                    <div class="text">
                        <span class="mono label">{c.label}</span>
                        <span class="value">{c.value}</span>
                    </div>
                    <i class="bi bi-arrow-up-right arrow"></i>
                </a>
            ))}
        </div>
    </section>
</BaseLayout>

<style lang="scss">
    .page {
        padding: 3rem 1.5rem 4rem;
        max-width: 48rem;
    }

    .head {
        margin-bottom: 3rem;

        .tag {
            display: block;
            color: var(--text-dim);
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }

        h1 {
            margin-bottom: 0.75rem;
            text-transform: lowercase;
        }

        p {
            font-size: 1.1rem;
            max-width: 34rem;
        }
    }

    .channels {
      display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .ch {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.25rem 1.5rem;
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 1rem;
        transition: transform 0.25s ease, border-color 0.25s ease;
        color: var(--text);

        &:hover {
            transform: translateX(4px);

            .arrow {
                transform: translate(3px, -3px);
                opacity: 1;
            }
        }

        &-red:hover { border-color: var(--red); .icon i { color: var(--red); } }
        &-blue:hover { border-color: var(--blue); .icon i { color: var(--blue); } }
    }

    .icon {
        width: 3rem;
        height: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--surface-2);
        border-radius: 0.75rem;

        i {
            font-size: 1.35rem;
            color: var(--text-muted);
            transition: color 0.25s ease;
        }
    }

    .text {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        flex-grow: 1;

        .label {
            color: var(--text-dim);
            font-size: 0.8rem;
        }

        .value {
            font-size: 1.05rem;
        }
    }

    .arrow {
        color: var(--text-dim);
        opacity: 0.5;
        transition: transform 0.25s ease, opacity 0.25s ease;
    }
</style>
